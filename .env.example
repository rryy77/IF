
# 本番サイト URL（OAuth 完了後のリダイレクト先）
NEXT_PUBLIC_SITE_URL=https://your-xapp.vercel.app
# または
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google OAuth（Gmail API）— redirect_uri は本番 URL のみ
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/gmail/callback

# Gmail search（さくら連絡網メールのみ）
GMAIL_SEARCH_QUERY=subject:(さくら連絡網 OR 学校連絡 OR 連絡網)
