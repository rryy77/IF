
# 本番サイト URL（OAuth 完了後のリダイレクト先）
NEXT_PUBLIC_SITE_URL=https://your-xapp.vercel.app
# または
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google OAuth（Gmail API）
# redirect_uri は NEXT_PUBLIC_SITE_URL + /api/gmail/callback で自動決定（推奨）
# 古い /api/auth/callback/google は使わないでください
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 任意（未設定可）。設定する場合は必ず /api/gmail/callback で終わること
# GOOGLE_REDIRECT_URI=https://f-mu.vercel.app/api/gmail/callback

# Gmail search（さくら連絡網メールのみ）
GMAIL_SEARCH_QUERY=subject:(さくら連絡網 OR 学校連絡 OR 連絡網)
